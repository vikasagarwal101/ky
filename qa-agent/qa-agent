def cmd_preflight(args):
    """Assess whether a repository is ready for standalone QA onboarding."""
    repo_path = Path(args.repo).resolve()
    if not repo_path.exists():
        print(f"Error: Repository path does not exist: {repo_path}")
        return 1

    config = ConfigManager()
    registry = RepoRegistry(config)
    health = HealthEngine()
    state = StateManager(config.repos_dir)
    plugins = PluginLoader(config.plugins_dir)
    engine = OnboardEngine(registry, plugins, health, state)

    language = engine.detect_language(repo_path)
    framework = engine.detect_framework(repo_path, language.name)
    plugin_id = engine.select_plugin(language.name, framework)
    package_hints = _package_manager_hints(repo_path)
    suggested_checks = _guess_validation_commands(repo_path, language.name)

    checks = []
    checks.append(_doctor_check('repo-path', repo_path.exists(), str(repo_path)))
    checks.append(_doctor_check('git', shutil.which('git') is not None, shutil.which('git') or 'missing'))
    checks.append(_doctor_check('gh', shutil.which('gh') is not None, shutil.which('gh') or 'missing'))
    checks.append(_doctor_check('runner', (config.workspace / 'core' / 'sandbox_local_runner.py').exists(), str(config.workspace / 'core' / 'sandbox_local_runner.py')))
    checks.append(_doctor_check('plugin', plugin_id is not None, plugin_id or f'no plugin for language={language.name}'))
    checks.append(_doctor_check('claude', shutil.which('claude') is not None, shutil.which('claude') or 'missing'))
    checks.append(_doctor_check('opencode', shutil.which('opencode') is not None, shutil.which('opencode') or 'missing'))

    git_ok = False
    git_detail = 'not a git repository'
    git_proc = _run_shell('git rev-parse --is-inside-work-tree', cwd=repo_path)
    if git_proc.returncode == 0:
        git_ok = git_proc.stdout.strip() == 'true'
        git_detail = 'git repository' if git_ok else git_proc.stdout.strip() or 'unknown'
    checks.append(_doctor_check('git-repo', git_ok, git_detail))

    gh_ok = False
    gh_detail = 'gh missing'
    if shutil.which('gh'):
        proc = _run_shell('gh auth status >/dev/null 2>&1')
        gh_ok = proc.returncode == 0
        gh_detail = 'authenticated' if gh_ok else 'not authenticated'
    checks.append(_doctor_check('gh-auth', gh_ok, gh_detail))

    docker_needed = (repo_path / 'docker-compose.yml').exists() or (repo_path / 'docker-compose.yaml').exists() or (repo_path / 'Dockerfile').exists()
    if docker_needed:
        if shutil.which('docker'):
            proc = _run_shell('docker ps >/dev/null 2>&1')
            checks.append(_doctor_check('docker', proc.returncode == 0, 'available' if proc.returncode == 0 else 'unavailable'))
        else:
            checks.append(_doctor_check('docker', False, 'missing'))

    clean_ok = True
    clean_detail = 'clean working tree'
    autoheal_note = None
    if git_ok:
        status_proc = _run_shell('git status --porcelain', cwd=repo_path)
        dirty = bool(status_proc.stdout.strip())
        clean_ok = not dirty
        if dirty:
            healer = TransientArtifactHealer(repo_path)
            if healer.is_exclusively_transient_dirty():
                autoheal_note = 'transient-artifact-only (auto-healable via qa-agent heal)'
                clean_detail = f'uncommitted changes (transient artifacts only)'
            else:
                clean_detail = 'uncommitted changes present (manual review needed)'
        else:
            clean_detail = 'clean working tree'
    checks.append(_doctor_check('safety-clean-tree', clean_ok, clean_detail))

    result = {
        'repo_path': str(repo_path),
        'language': language.name,
        'secondary_languages': language.secondary_languages,
        'framework': framework,
        'plugin_id': plugin_id,
        'package_hints': package_hints,
        'suggested_validation_commands': suggested_checks,
        'checks': checks,
        'ready': all(check['ok'] for check in checks if check['name'] not in {'claude', 'opencode', 'safety-clean-tree'}),
        'autoheal_note': autoheal_note,
    }

    if args.format == 'json':
        print(json.dumps(result, indent=2))
        return 0 if result['ready'] else 1

    if args.format == 'whatsapp':
        lines = [
            f"QA preflight: {repo_path.name}",
            f"Language: {language.name}" + (f" + {', '.join(language.secondary_languages)}" if language.secondary_languages else "") + f" | Framework: {framework or 'n/a'} | Plugin: {plugin_id or 'none'}",
            f"Package hints: {', '.join(package_hints) if package_hints else 'none'}",
            f"Default safety: mode observe | profile conservative",
        ]
        if suggested_checks:
            lines.append('Suggested validation: ' + ' ; '.join(' '.join(cmd) for cmd in suggested_checks))
        for check in checks:
            lines.append(f"{'✅' if check['ok'] else '❌'} {check['name']}: {check['detail']}")
        print('\n'.join(lines))
        return 0 if result['ready'] else 1

    print(f"QA preflight: {repo_path}")
    print('=' * 60)
    print(f"Language: {language.name}")
    if language.secondary_languages:
        print(f"Secondary languages: {', '.join(language.secondary_languages)} (mixed repo)")
    print(f"Framework: {framework or 'n/a'}")
    print(f"Plugin: {plugin_id or 'none'}")
    print(f"Package hints: {', '.join(package_hints) if package_hints else 'none'}")
    if suggested_checks:
        print('Suggested validation commands:')
        for cmd in suggested_checks:
            print('  - ' + ' '.join(cmd))
    print('\nChecks:')
    for check in checks:
        print(f"  {'OK' if check['ok'] else 'FAIL':<5} {check['name']}: {check['detail']}")
    if autoheal_note:
        print(f"\n  💡 {autoheal_note}")
    print(f"\nReady for onboarding: {'yes' if result['ready'] else 'no'}")
    return 0 if result['ready'] else 1


def cmd_onboard(args):
    """Onboard a new repository."""
    from pathlib import Path
    
    repo_path = Path(args.repo).resolve()
    
    if not repo_path.exists():
        print(f"Error: Repository path does not exist: {repo_path}")
        return 1
    
    config = ConfigManager()
    registry = RepoRegistry(config)
    health = HealthEngine()
    state = StateManager(config.repos_dir)
    
    plugins = PluginLoader(config.plugins_dir)
    
    engine = OnboardEngine(registry, plugins, health, state)

    # Self-heal transient artifacts before onboarding if dirty tree is exclusively transient
    healer = TransientArtifactHealer(repo_path)
    if healer.is_dirty():
        safe, reason = healer.safe_to_autoheal(require_clean_worktree=True)
        if safe:
            heal_result = healer.heal(remove_artifacts=True, dry_run=False)
            print(f"💡 Auto-healed transient artifacts: .gitignore updated, {len(heal_result['artifacts_removed'])} artifact(s) removed")
    
    print(f"🔍 Onboarding repository: {repo_path}")
    
    try:
        result = engine.onboard(
            repo_path,
            OnboardOptions(
                name=args.name,
                language=args.language,
                template=args.template,
                capture_baseline=not args.skip_baseline,
                mode=args.mode,
                profile=args.profile,
                allow_dirty_worktree=args.allow_dirty_worktree,
            )
        )
        
        print(f"\n✅ Repository onboarded successfully!")
        print(f"\n📋 Details:")
        print(f"   Name: {result.repo.config.name}")
        lang_label = result.language.name
        if result.language.secondary_languages:
            lang_label += f" + {', '.join(result.language.secondary_languages)} (mixed)"
        print(f"   Language: {lang_label}")
        print(f"   Framework: {result.repo.config.framework or 'Not detected'}")
        print(f"   Package manager: {result.language.package_manager or 'Not detected'}")
        print(f"   Build tool: {result.language.build_tool or 'Not detected'}")
        print(f"   Plugin: {result.plugin_id}")
        print(f"   Template: {result.template or 'heuristic-default'}")
        print(f"   Fix engine: {result.repo.config.fix_engine}")
        print(f"   Fallbacks: {', '.join(result.repo.config.fallback_engines)}")
        print(f"   Safety mode: {result.repo.config.safety.get('mode', 'observe')}")
        print(f"   Safety profile: {result.repo.config.safety.get('profile', 'conservative')}")
        print(f"\n📊 Initial Assessment:")
        print(f"   Findings: {result.findings_count}")
        if result.health:
            print(f"   Health Score: {result.health.score}/100 ({result.health.band})")
        
        if result.baseline:
            print(f"\n📸 Baseline captured: {result.baseline.id}")

        if result.suggested_checks:
            print(f"\n🧪 Inferred baseline checks:")
            for cmd in result.suggested_checks:
                print(f"   - {' '.join(cmd)}")

        if result.review_items:
            print(f"\n⚠️ Review before live runs:")
            for item in result.review_items:
                print(f"   - {item}")
        
        print(f"\n🚀 Next steps:")
        print(f"   Preflight: qa-agent preflight --repo {repo_path}")
        print(f"   Run: qa-agent run --repo {result.repo.config.name} --phase issue-cycle --dry-run")
        print(f"   Status: qa-agent repos show {result.repo.config.name}")
        
        return 0
        
    except Exception as e:
        print(f"\n❌ Onboarding failed: {e}")
        return 1


def _phase_allowed_for_mode(mode: str, phase: str, dry_run: bool) -> tuple[bool, str]:
    if dry_run:
        return True, ''
    if mode == SafetyMode.OBSERVE.value:
        return False, 'Observe mode blocks non-dry-run execution.'
    if mode == SafetyMode.ISSUE_ONLY.value and phase in {'pr-cycle', 'merge-cycle'}:
        return False, 'Issue-only mode blocks PR and merge execution.'
    if mode == SafetyMode.PR.value and phase == 'merge-cycle':
        return False, 'PR mode blocks merge execution.'
    return True, ''


def cmd_run(args):
    """Run QA cycle on a repository."""
    config = ConfigManager()
    registry = RepoRegistry(config)
    health = HealthEngine()
    state = StateManager(config.repos_dir)
    
    # Find repo
    repo = registry.find_by_name(args.repo)
    if not repo:
        print(f"Error: Repository not found: {args.repo}")
        return 1
    
    if not repo.config.enabled:
        print(f"Error: Repository is disabled: {args.repo}")
        return 1

    allowed, reason = _phase_allowed_for_mode(repo.config.safety.get('mode', SafetyMode.OBSERVE.value), args.phase, args.dry_run)
    if not allowed:
        print(f"Error: {reason}")
        return 1

    if not args.dry_run and repo.config.safety.get('require_clean_worktree', True):
        repo_path = Path(repo.config.path)
        healer = TransientArtifactHealer(repo_path)
        if healer.is_dirty():
            safe, reason = healer.safe_to_autoheal(require_clean_worktree=True)
            if safe:
                heal_result = healer.heal(remove_artifacts=True, dry_run=False)
                print(f'💡 Auto-healed transient artifacts before run: {len(heal_result["artifacts_removed"])} removed, {len(heal_result["gitignore_entries_added"])} .gitignore entries added')
            else:
                print(f'Error: Live execution blocked because the repository working tree is dirty.')
                return 1
    
    # Setup runner
    runner = RunEngine(registry, state, health, config)
    
    print(f"🏃 Running {args.phase} cycle on {args.repo}...")
    print(f"   Dry run: {args.dry_run}")
    
    # Execute
    result = runner.run(repo, RunOptions(
        phase=args.phase,
        dry_run=args.dry_run,
        fix_engine=args.fix_engine,
        allow_review_push=args.allow_review_push,
    ))
    
    # Print results
    print(f"\n📊 Results:")
    print(f"   Status: {result.run.status}")
    print(f"   Duration: {result.run.duration_seconds}s")
    print(f"   Findings: {result.run.findings_detected}")
    print(f"   Issues: {result.run.issues_created}")
    print(f"   Fixes: {result.run.fixes_verified}/{result.run.fix_attempts}")
    print(f"   PRs: {result.run.prs_created}")
    
    if result.run.health_delta != 0:
        delta = f"+{result.run.health_delta}" if result.run.health_delta > 0 else str(result.run.health_delta)
        print(f"\n📈 Health: {result.run.health_before:.1f} → {result.run.health_after:.1f} ({delta})")
    
    if result.error:
        print(f"\n❌ Error: {result.error}")
        return 1
    
    return 0


def cmd_report(args):
    """Generate a report for a repository."""
    from qa_agent.report import ReportGenerator
    from qa_agent.health import HealthEngine

    config = ConfigManager()
    registry = RepoRegistry(config)
    health_engine = HealthEngine()
    state = StateManager(config.repos_dir)

    repo = registry.find_by_name(args.repo)
    if not repo:
        print(f"Error: Repository not found: {args.repo}")
        return 1

    # Get health history
    history = health_engine.get_health_history(
        args.repo,
        state._get_state_dir(args.repo),
        days=args.days
    )

    # Get findings by category
    findings = state.load_findings(args.repo)
    findings_by_category = {}
    for finding in findings:
        key = finding.category or finding.rule or 'unknown'
        findings_by_category[key] = findings_by_category.get(key, 0) + 1
    issues = state.load_issues(args.repo)
    runs = state.list_runs(args.repo, limit=max(10, args.days * 6))

    # Get baseline
    baselines = state.list_baselines(args.repo)
    baseline = None
    if baselines:
        baseline_data = state.load_baseline(args.repo, baselines[0])
        if baseline_data:
            from qa_agent.models import Baseline
            baseline = Baseline(**baseline_data) if isinstance(baseline_data, dict) else None

    # Calculate current health
    health = health_engine.calculate(findings)

    # Get review care diagnostics
    review_care = _load_review_care_diagnostics(state, args.repo)

    if args.format in {'text', 'whatsapp'}:
        print(_text_report_summary(repo, findings, issues, runs, args.days, review_care))
        return 0

    print(f"Generating report for {args.repo}...")
    generator = ReportGenerator()
    output_path = Path(args.output) if args.output else None

    report_path = generator.generate_pdf(
        repo=repo,
        baseline=baseline,
        health=health,
        history=history,
        findings_by_category=findings_by_category,
        output_path=output_path,
        review_care=review_care,
    )

    print(f"\nReport generated: {report_path}")
    return 0


