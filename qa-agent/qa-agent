def _status_icon(status):
    return {
        RepoStatus.READY: '✅',
        RepoStatus.RUNNING: '🏃',
        RepoStatus.PAUSED: '⏸️',
        RepoStatus.ERROR: '❌',
        RepoStatus.IDLE: '💤',
        RepoStatus.ONBOARDING: '🔄',
    }.get(status, '❓')


def _health_icon(score: float) -> str:
    if score >= 70:
        return '🟢'
    if score >= 50:
        return '🟡'
    return '🔴'


def _load_recent_runs(state: StateManager, repo_name: str, limit: int = 5):
    return state.list_runs(repo_name, limit=limit)


def _load_status_artifact(state: StateManager, repo_name: str) -> dict:
    status_file = state._get_state_dir(repo_name) / 'status.json'
    if not status_file.exists():
        return {}
    try:
        return json.loads(status_file.read_text())
    except Exception:
        return {}


def _fmt_ts(value: str | None) -> str:
    if not value:
        return 'never'
    try:
        dt = datetime.fromisoformat(value.replace('Z', '+00:00'))
        return dt.astimezone().strftime('%Y-%m-%d %H:%M')
    except Exception:
        return value


def _whatsapp_repo_summary(repo, recent_runs, status_artifact=None):
    last_run = recent_runs[0] if recent_runs else None
    last_phase = last_run.get('phase') if last_run else 'n/a'
    last_status = last_run.get('status') if last_run else repo.status.value
    lines = [
        f"{_status_icon(repo.status)} {repo.config.name}",
        f"Health: {_health_icon(repo.current_health_score)} {repo.current_health_score:.1f}/100",
        f"Findings: {repo.current_findings_count} | Fixes: {repo.total_fixes} | PRs: {repo.total_prs} | Merges: {repo.total_merges}",
        f"Last: {last_phase} -> {last_status} @ {_fmt_ts(repo.last_run_at)}",
    ]
    review = (status_artifact or {}).get('review_care') or {}
    if review:
        lines.append(
            f"Review: active {review.get('active_managed_prs', 0)} | blocked {review.get('review_blocked_prs', 0)} | planned {review.get('retry_planned_prs', 0)} | prepared {review.get('retry_prepared_prs', 0)} | executed {review.get('retry_executed_prs', 0)} | pending-push {review.get('pending_push_prs', 0)} | push-failed {review.get('failed_push_prs', 0)} | exhausted {review.get('retry_exhausted_prs', 0)} | ready {review.get('merge_ready_prs', 0)}"
        )
    return '\n'.join(lines)


def _text_report_summary(repo, findings, issues, runs, days: int, review_care: dict = None) -> str:
    open_issues = len([x for x in issues.get('issues', []) if x.get('status') == 'open'])
    created_prs = sum(int(run.get('prs_created', 0)) for run in runs)
    verified_fixes = sum(int(run.get('fixes_verified', 0)) for run in runs)
    failures = [run for run in runs if run.get('status') not in {'completed', 'ok'}]
    lines = [
        f"QA report: {repo.config.name}",
        f"Health: {repo.current_health_score:.1f}/100 | Findings: {len(findings)} | Open issues: {open_issues}",
        f"Last {days}d runs: {len(runs)} | Verified fixes: {verified_fixes} | PRs created: {created_prs}",
    ]
    if failures:
        lines.append(f"Recent failures: {len(failures)} (latest: {failures[0].get('phase')} -> {failures[0].get('status')})")
    if runs:
        latest = runs[0]
        lines.append(f"Latest run: {latest.get('phase')} -> {latest.get('status')} @ {_fmt_ts(latest.get('ended_at') or latest.get('started_at'))}")
    if review_care and review_care.get('active_managed_prs', 0) > 0:
        lines.append(
            f"Review care: active={review_care.get('active_managed_prs')} blocked={review_care.get('review_blocked_prs')} "
            f"pending-push={review_care.get('pending_push_prs', 0)} push-failed={review_care.get('failed_push_prs', 0)} "
            f"exhausted={review_care.get('retry_exhausted_prs')} ready={review_care.get('merge_ready_prs')}"
        )
    return '\n'.join(lines)


def _doctor_check(name: str, ok: bool, detail: str) -> dict:
    return {'name': name, 'ok': ok, 'detail': detail}


def _run_shell(command: str, cwd: Path | None = None) -> subprocess.CompletedProcess:
    return subprocess.run(
        ['bash', '-lc', command],
        cwd=str(cwd) if cwd else None,
        text=True,
        capture_output=True,
    )


def _package_manager_hints(repo_path: Path) -> list[str]:
    hints = []
    if (repo_path / 'pnpm-lock.yaml').exists():
        hints.append('pnpm')
    if (repo_path / 'package-lock.json').exists():
        hints.append('npm')
    if (repo_path / 'yarn.lock').exists():
        hints.append('yarn')
    if (repo_path / 'bun.lock').exists() or (repo_path / 'bun.lockb').exists():
        hints.append('bun')
    if (repo_path / 'requirements.txt').exists() or (repo_path / 'pyproject.toml').exists():
        hints.append('python')
    return hints


def _guess_validation_commands(repo_path: Path, language: str) -> list[list[str]]:
    commands: list[list[str]] = []
    package_json = repo_path / 'package.json'
    if language in {'typescript', 'javascript'} and package_json.exists():
        try:
            pkg = json.loads(package_json.read_text())
            scripts = pkg.get('scripts', {})
            if 'test' in scripts:
                commands.append(['npm', 'test'])
            if 'lint' in scripts:
                commands.append(['npm', 'run', 'lint'])
            if 'build' in scripts:
                commands.append(['npm', 'run', 'build'])
            if 'typecheck' in scripts:
                commands.append(['npm', 'run', 'typecheck'])
        except Exception:
            pass
    if language == 'python':
        if (repo_path / 'pytest.ini').exists() or (repo_path / 'pyproject.toml').exists() or (repo_path / 'tests').exists():
            commands.append(['pytest', '-q'])
        if (repo_path / 'pyproject.toml').exists() or (repo_path / '.ruff.toml').exists():
            commands.append(['ruff', 'check', '.'])
    return commands


def cmd_status(args):
    """Show agent status."""
    config = ConfigManager()
    registry = RepoRegistry(config)
    state = StateManager(config.repos_dir)

    if getattr(args, 'repo', None):
        repo = registry.find_by_name(args.repo)
        if not repo:
            print(f"Error: Repository not found: {args.repo}")
            return 1
        recent_runs = _load_recent_runs(state, repo.config.name, limit=5)
        status_artifact = _load_status_artifact(state, repo.config.name)
        if args.format == 'whatsapp':
            print(_whatsapp_repo_summary(repo, recent_runs, status_artifact))
            return 0
        if args.format == 'json':
            print(json.dumps({'repo': repo.to_dict(), 'recent_runs': recent_runs}, indent=2))
            return 0

        print(f"QA Agent Status: {repo.config.name}")
        print("=" * 60)
        print(f"Status: {_status_icon(repo.status)} {repo.status.value}")
        print(f"Health: {_health_icon(repo.current_health_score)} {repo.current_health_score:.1f}/100")
        print(f"Language: {repo.config.language}")
        print(f"Findings: {repo.current_findings_count}")
        print(f"Fix engine: {repo.config.fix_engine}")
