                        for pr in rc.get('failed_push_prs_detail', [])[:3]:
                            lines.append(f"    push failed: PR #{pr['pr_number']} branch={pr['branch']} status={pr.get('push_status') or pr['status']}")
        print('\n'.join(lines))
        return 0 if all(c['ok'] for c in checks) else 1

    print('QA Agent Doctor')
    print('=' * 60)
    for check in checks:
        print(f"{'OK' if check['ok'] else 'FAIL':<5} {check['name']}: {check['detail']}")
    print('\nRepositories')
    print('-' * 60)
    for report in repo_reports:
        if 'error' in report:
            print(f"{report['repo']}: {report['error']}")
        else:
            print(f"{report['repo']}: status={report['status']} health={report['health']:.1f} findings={report['findings']} backend={report['fix_engine']} last={report['last_phase']}->{report['last_run']}")
            rc = report.get('review_care', {})
            if rc.get('active_managed_prs', 0) > 0 or rc.get('enabled'):
                print(f"  Review care: enabled={rc.get('enabled')} active={rc.get('active_managed_prs')} blocked={rc.get('review_blocked_prs')} planned={rc.get('retry_planned_prs')} prepared={rc.get('retry_prepared_prs')} executed={rc.get('retry_executed_prs')} pending-push={rc.get('pending_push_prs', 0)} push-failed={rc.get('failed_push_prs', 0)} failed={rc.get('retry_failed_prs')} exhausted={rc.get('retry_exhausted_prs')} ready={rc.get('merge_ready_prs')} paused={rc.get('paused_prs')}")
                if rc.get('last_review_cycle_at'):
                    print(f"    last review cycle: {_fmt_ts(rc.get('last_review_cycle_at'))}")
                if rc.get('pending_push_prs_detail'):
                    for pr in rc.get('pending_push_prs_detail', [])[:3]:
