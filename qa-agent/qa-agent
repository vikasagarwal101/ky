                rc = report.get('review_care', {})
                if rc.get('active_managed_prs', 0) > 0:
                    lines.append(f"  review: active={rc.get('active_managed_prs')} blocked={rc.get('review_blocked_prs')} pending-push={rc.get('pending_push_prs', 0)} push-failed={rc.get('failed_push_prs', 0)} exhausted={rc.get('retry_exhausted_prs')}")
                    if rc.get('pending_push_prs_detail'):
                        for pr in rc.get('pending_push_prs_detail', [])[:3]:
