    print("\n" + "=" * 52)
    print(f" QA Agent setup complete for '{repo_name}'")
    print("=" * 52)
    print(f"\n  Next steps:")
    print(f"    ./qa-agent status --repo {repo_name}")
    print(f"    ./qa-agent run --repo {repo_name} --phase issue-cycle --dry-run")
    print(f"\n  See ./qa-agent --help for all commands.")
    return 0


