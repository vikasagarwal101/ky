                if rc.get('failed_push_prs_detail'):
                    for pr in rc.get('failed_push_prs_detail', [])[:3]:
                        print(f"    PUSH FAILED: PR #{pr['pr_number']} branch={pr['branch']} push_status={pr.get('push_status') or pr['status']}")
