    # Detect install method
    npm_pkg = root / 'package.json'
    is_npm_install = npm_pkg.exists()
    git_dir = root / '.git'

    if is_npm_install:
        print("→ Updating via npm...")
        r = subprocess.run(['npm', 'update', '-g'], capture_output=True, text=True)
        if r.returncode != 0:
            print(f"✗ npm update failed: {r.stderr}")
            return 1
        print("✓ Updated via npm")
        print(f"  Run: qa-agent --version to verify")
        return 0

    if git_dir.exists():
        print("→ Updating via git pull...")
        r = subprocess.run(['git', '-C', str(root), 'pull', '--ff-only'], capture_output=True, text=True)
        if r.returncode != 0:
            print(f"✗ git pull failed: {r.stderr}")
            print("  If you have local changes, stash or reset first.")
            return 1
        print("✓ Updated via git pull")
        # Reinstall deps in case requirements changed
        venv_py = root / '.venv' / 'bin' / 'python3'
        if venv_py.exists():
            print("→ Updating Python dependencies...")
            req = root / 'requirements.txt'
            if req.exists():
                subprocess.run([str(venv_py), '-m', 'pip', 'install', '-r', str(req), '-q'])
        print(f"  Run: qa-agent --version to verify")
        return 0

    print("✗ Could not determine how qa-agent was installed.")
    print("  Install method not detected (no .git and no package.json).")
    print("  To install: git clone <repo> or npm install -g <package>")
    return 1


def main():
    parser = argparse.ArgumentParser(
        description='QA Agent - Autonomous Repository Quality Assurance',
        prog='qa-agent'
    )
    parser.add_argument('--version', action='version', version=f'%(prog)s {__version__}')
    
    subparsers = parser.add_subparsers(dest='command', help='Available commands')
    
    # status
    status_parser = subparsers.add_parser('status', help='Show agent status')
    status_parser.add_argument('--repo', help='Repository name')
    status_parser.add_argument('--format', choices=['text', 'whatsapp', 'json'], default='text', help='Output format')
    
    # repos
    repos_parser = subparsers.add_parser('repos', help='Repository management')
    repos_sub = repos_parser.add_subparsers(dest='repos_command', help='Repo commands')
    
    repos_sub.add_parser('list', help='List all repos')
    
    repos_show = repos_sub.add_parser('show', help='Show repo details')
    repos_show.add_argument('repo', help='Repository name')
    
    # preflight
    preflight_parser = subparsers.add_parser('preflight', help='Assess a repository before onboarding')
    preflight_parser.add_argument('--repo', required=True, help='Path to repository')
    preflight_parser.add_argument('--format', choices=['text', 'whatsapp', 'json'], default='text', help='Output format')

    # onboard
    onboard_parser = subparsers.add_parser('onboard', help='Onboard a new repository')
    onboard_parser.add_argument('--repo', required=True, help='Path to repository')
    onboard_parser.add_argument('--name', help='Repository name (default: directory name)')
    onboard_parser.add_argument('--language', help='Force language detection')
    onboard_parser.add_argument('--template', help='Explicit repo template to use')
    onboard_parser.add_argument('--skip-baseline', action='store_true', help='Skip baseline capture')
    onboard_parser.add_argument('--mode', choices=['observe', 'issue-only', 'pr', 'merge'], default='observe', help='Safety mode')
    onboard_parser.add_argument('--profile', choices=['conservative', 'balanced', 'aggressive'], default='conservative', help='Safety profile')
    onboard_parser.add_argument('--allow-dirty-worktree', action='store_true', help='Allow onboarding without a clean working tree')
    
    # run
    run_parser = subparsers.add_parser('run', help='Run QA cycle')
    run_parser.add_argument('--repo', required=True, help='Repository name')
    run_parser.add_argument('--phase', default='orchestrated', 
                            choices=['issue-cycle', 'pr-cycle', 'review-cycle', 'merge-cycle', 'orchestrated', 'verify-only'],
                            help='Run phase')
    run_parser.add_argument('--dry-run', action='store_true', default=True, help='Dry run (preview only)')
    run_parser.add_argument('--no-dry-run', action='store_false', dest='dry_run', help='Execute for real')
    run_parser.add_argument('--fix-engine', choices=['auto', 'deterministic', 'claude', 'opencode'], help='Fix engine to use')
    run_parser.add_argument('--allow-review-push', action='store_true', help='Allow review-cycle to commit and push validated remediation changes')
    
    # health
    health_parser = subparsers.add_parser('health', help='Show health score')
    health_parser.add_argument('--repo', required=True, help='Repository name')
    health_parser.add_argument('--days', type=int, default=30, help='Days of history')
    health_parser.add_argument('--format', choices=['text', 'whatsapp'], default='text', help='Output format')
    
    # report
    report_parser = subparsers.add_parser('report', help='Generate report')
    report_parser.add_argument('--repo', required=True, help='Repository name')
    report_parser.add_argument('--output', '-o', help='Output file path')
    report_parser.add_argument('--days', type=int, default=30, help='Days of history')
    report_parser.add_argument('--format', choices=['pdf', 'text', 'whatsapp'], default='pdf', help='Output format')

    # doctor
    doctor_parser = subparsers.add_parser('doctor', help='Run operational checks')
    doctor_parser.add_argument('--repo', help='Repository name')
    doctor_parser.add_argument('--format', choices=['text', 'whatsapp', 'json'], default='text', help='Output format')

    # install-cron
    cron_parser = subparsers.add_parser('install-cron', help='Install host cron schedule for a repo')
    cron_parser.add_argument('--repo', required=True, help='Repository name')
    cron_parser.add_argument('--issue-schedule', default='0 */4 * * *', help='Cron schedule for issue-cycle')
    cron_parser.add_argument('--pr-schedule', default='0 */6 * * *', help='Cron schedule for pr-cycle')
    cron_parser.add_argument('--review-schedule', default='30 * * * *', help='Cron schedule for review-cycle')
    cron_parser.add_argument('--merge-schedule', default='0 6,18 * * *', help='Cron schedule for merge-cycle')

    # heal
    heal_parser = subparsers.add_parser('heal', help='Heal dirty worktree caused by transient artifacts')
    heal_parser.add_argument('--repo', required=True, help='Path to repository')
    heal_parser.add_argument('--dry-run', action='store_true', default=True, help='Preview healing actions (default)')
    heal_parser.add_argument('--no-dry-run', action='store_false', dest='dry_run', help='Execute healing (update .gitignore and remove artifacts)')
    heal_parser.add_argument('--remove-artifacts', action='store_true', default=False, help='Also remove transient artifact directories/files')
    heal_parser.add_argument('--force', action='store_true', help='Force heal even when not exclusively transient (not recommended)')

    # init
    init_parser = subparsers.add_parser('init', help='Interactive first-run setup wizard')

    # update
    update_parser = subparsers.add_parser('update', help='Self-update qa-agent to the latest version')

    args = parser.parse_args()
    
    if args.command == 'status':
        return cmd_status(args)
    elif args.command == 'repos':
        if args.repos_command == 'list':
            return cmd_repos_list(args)
        elif args.repos_command == 'show':
            return cmd_repos_show(args)
        else:
            repos_parser.print_help()
            return 0
    elif args.command == 'preflight':
        return cmd_preflight(args)
    elif args.command == 'onboard':
        return cmd_onboard(args)
    elif args.command == 'run':
        return cmd_run(args)
    elif args.command == 'health':
        return cmd_health(args)
    elif args.command == 'report':
        return cmd_report(args)
    elif args.command == 'doctor':
        return cmd_doctor(args)
    elif args.command == 'install-cron':
        return cmd_install_cron(args)
    elif args.command == 'heal':
        return cmd_heal(args)
    elif args.command == 'init':
        return cmd_init(args)
    elif args.command == 'update':
        return cmd_update(args)
    else:
        parser.print_help()
        return 0


if __name__ == '__main__':
    sys.exit(main())
