            'ISSUE_SCHEDULE': issue_schedule,
            'PR_SCHEDULE': '0 */6 * * *',
            'REVIEW_SCHEDULE': '30 * * * *',
            'MERGE_SCHEDULE': '0 6,18 * * *',
            'INCLUDE_PR': '1' if safety_mode in {'pr', 'merge'} else '0',
            'INCLUDE_REVIEW': '1',
            'INCLUDE_MERGE': '1' if safety_mode == 'merge' else '0',
        }
        script = Path(__file__).resolve().parents[1] / 'scripts' / 'install-cron.sh'
