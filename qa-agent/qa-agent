def cmd_install_cron(args):
    """Install host cron entries for a repo."""
    config = ConfigManager()
    repo = RepoRegistry(config).find_by_name(args.repo)
    if not repo:
        print(f"Error: Repository not found: {args.repo}")
        return 1

    script = config.workspace / 'scripts' / 'install-cron.sh'
    if not script.exists():
        print(f"Error: Cron installer not found: {script}")
        return 1

    mode = (repo.config.safety or {}).get('mode', SafetyMode.OBSERVE.value)
    include_pr = '1' if mode in {SafetyMode.PR.value, SafetyMode.MERGE.value} else '0'
    # Review-cycle manages existing PRs and retries; safe to run in ISSUE_ONLY and above
    include_review = '1' if mode in {SafetyMode.ISSUE_ONLY.value, SafetyMode.PR.value, SafetyMode.MERGE.value} else '0'
    include_merge = '1' if mode == SafetyMode.MERGE.value else '0'

    env = {
        **os.environ,
        'ISSUE_SCHEDULE': args.issue_schedule,
        'PR_SCHEDULE': args.pr_schedule,
        'REVIEW_SCHEDULE': args.review_schedule,
        'MERGE_SCHEDULE': args.merge_schedule,
        'INCLUDE_PR': include_pr,
        'INCLUDE_REVIEW': include_review,
        'INCLUDE_MERGE': include_merge,
    }
    proc = subprocess.run([str(script), args.repo], text=True, capture_output=True, env=env)
    output = (proc.stdout or '') + (('\n' + proc.stderr) if proc.stderr else '')
    print(output.strip())
    return proc.returncode


def cmd_heal(args):
    """Heal a dirty worktree by updating .gitignore and/or removing transient artifacts."""
    repo_path = Path(args.repo).resolve()
    if not repo_path.exists():
        print(f"Error: Repository path does not exist: {repo_path}")
        return 1

    healer = TransientArtifactHealer(repo_path)

    if not healer.is_dirty():
        print(f"Working tree is already clean for {repo_path}")
        return 0

    safe, reason = healer.safe_to_autoheal(require_clean_worktree=not args.force)
    if not safe and not args.force:
        print(f"Cannot auto-heal: {reason}")
        print("Use --force to heal anyway (not recommended).")
        return 1

    heal_result = healer.heal(
        remove_artifacts=args.remove_artifacts,
        dry_run=args.dry_run,
    )

    if args.dry_run:
        print(f"[dry-run] Would heal transient artifacts for: {repo_path}")
    else:
        print(f"Healed transient artifacts for: {repo_path}")

    if heal_result['gitignore_entries_added']:
        print(f"  .gitignore entries added: {', '.join(heal_result['gitignore_entries_added'])}")
    if heal_result['artifacts_removed']:
        print(f"  Artifacts removed: {', '.join(heal_result['artifacts_removed'])}")

    remaining = healer.get_dirty_paths()
    if remaining and not args.dry_run:
        print(f"\n  Remaining dirty paths (non-transient, manual review needed):")
        for p in remaining[:10]:
            print(f"    - {p}")
        if len(remaining) > 10:
            print(f"    ... and {len(remaining) - 10} more")

    return 0


def _load_review_care_diagnostics(state: StateManager, repo_name: str) -> dict:
    """Load review-care diagnostics for a repo."""
    status_artifact = _load_status_artifact(state, repo_name)
    review_care = status_artifact.get('review_care', {})
    active_prs = state.load_active_prs(repo_name)
    review_state = state.load_review_state(repo_name)

    pr_list = active_prs.get('prs', {})
    blocked_prs = []
    exhausted_prs = []
    paused_prs = []
    ready_prs = []
    pending_push_prs = []
    failed_push_prs = []

    for pr_key, pr_data in pr_list.items():
        pr_number = pr_data.get('pr_number', pr_key)
        status = pr_data.get('status', 'unknown')
        merge_state = (pr_data.get('merge_readiness') or {}).get('state', 'unknown')
        review_record = (review_state.get('prs', {}).get(pr_key, {}))
        execution_result = pr_data.get('execution_result') or review_record.get('execution_result') or {}
        push_result = execution_result.get('push_result') or {}
        attempts = review_record.get('attempts_used', 0)

        pr_info = {
            'pr_number': pr_number,
            'status': status,
            'merge_state': merge_state,
            'attempts': attempts,
            'branch': pr_data.get('branch', 'unknown'),
            'push_status': push_result.get('status'),
            'push_target_branch': push_result.get('target_branch'),
            'changed_files': execution_result.get('changed_files') or [],
            'last_action_reason': review_record.get('last_action_reason'),
        }

        if status == 'retry_exhausted':
            exhausted_prs.append(pr_info)
        elif status == 'loop_guard_paused':
            paused_prs.append(pr_info)
        elif status == 'retry_pending_push' or merge_state == 'awaiting_operator_push':
            pending_push_prs.append(pr_info)
        elif status == 'retry_failed_push':
            failed_push_prs.append(pr_info)
        elif merge_state == 'blocked_by_review':
            blocked_prs.append(pr_info)
        elif merge_state == 'ready_for_merge':
            ready_prs.append(pr_info)

    return {
        'enabled': review_care.get('enabled', False),
        'active_managed_prs': review_care.get('active_managed_prs', 0),
        'review_blocked_prs': review_care.get('review_blocked_prs', 0),
        'retry_eligible_prs': review_care.get('retry_eligible_prs', 0),
        'retry_planned_prs': review_care.get('retry_planned_prs', 0),
        'retry_prepared_prs': review_care.get('retry_prepared_prs', 0),
        'retry_executed_prs': review_care.get('retry_executed_prs', 0),
        'retry_failed_prs': review_care.get('retry_failed_prs', 0),
        'retry_exhausted_prs': review_care.get('retry_exhausted_prs', 0),
        'merge_ready_prs': review_care.get('merge_ready_prs', 0),
        'paused_prs': review_care.get('paused_prs', 0),
        'last_review_cycle_at': review_care.get('last_review_cycle_at'),
        'blocked_prs_detail': blocked_prs,
        'exhausted_prs_detail': exhausted_prs,
        'paused_prs_detail': paused_prs,
        'ready_prs_detail': ready_prs,
        'pending_push_prs_detail': pending_push_prs,
        'failed_push_prs_detail': failed_push_prs,
        'pending_push_prs': len(pending_push_prs),
        'failed_push_prs': len(failed_push_prs),
    }


def cmd_doctor(args):
    """Run operational checks for the standalone QA agent."""
    config = ConfigManager()
    registry = RepoRegistry(config)
    state = StateManager(config.repos_dir)

    repo_names = [args.repo] if args.repo else [r.config.name for r in registry.list_all()]
    checks = []
    checks.append(_doctor_check('python3', shutil.which('python3') is not None, shutil.which('python3') or 'missing'))
    checks.append(_doctor_check('git', shutil.which('git') is not None, shutil.which('git') or 'missing'))
    checks.append(_doctor_check('gh', shutil.which('gh') is not None, shutil.which('gh') or 'missing'))
    checks.append(_doctor_check('claude', shutil.which('claude') is not None, shutil.which('claude') or 'missing'))
    checks.append(_doctor_check('opencode', shutil.which('opencode') is not None, shutil.which('opencode') or 'missing'))
    checks.append(_doctor_check('runner', (config.workspace / 'core' / 'sandbox_local_runner.py').exists(), str(config.workspace / 'core' / 'sandbox_local_runner.py')))

    gh_ok = False
    gh_detail = 'gh missing'
    if shutil.which('gh'):
        proc = subprocess.run(['bash', '-lc', 'gh auth status >/dev/null 2>&1'], text=True)
        gh_ok = proc.returncode == 0
        gh_detail = 'authenticated' if gh_ok else 'not authenticated'
    checks.append(_doctor_check('gh-auth', gh_ok, gh_detail))

    if shutil.which('docker'):
        proc = subprocess.run(['bash', '-lc', 'docker ps >/dev/null 2>&1'], text=True)
        checks.append(_doctor_check('docker', proc.returncode == 0, 'available' if proc.returncode == 0 else 'unavailable'))
    else:
        checks.append(_doctor_check('docker', False, 'missing'))

    repo_reports = []
    for repo_name in repo_names:
        repo = registry.find_by_name(repo_name)
        if not repo:
            repo_reports.append({'repo': repo_name, 'error': 'not found'})
            continue
        runs = state.list_runs(repo_name, limit=5)
        latest = runs[0] if runs else None
        review_care_diag = _load_review_care_diagnostics(state, repo_name)
        repo_reports.append({
            'repo': repo_name,
            'enabled': repo.config.enabled,
            'status': repo.status.value,
            'fix_engine': repo.config.fix_engine,
            'fallbacks': repo.config.fallback_engines,
            'last_run': latest.get('status') if latest else 'never',
            'last_phase': latest.get('phase') if latest else 'n/a',
            'health': repo.current_health_score,
            'findings': repo.current_findings_count,
            'review_care': review_care_diag,
        })

    if args.format == 'json':
        print(json.dumps({'checks': checks, 'repos': repo_reports}, indent=2))
        return 0 if all(c['ok'] for c in checks) else 1

    if args.format == 'whatsapp':
        lines = ['QA Agent Doctor']
        for check in checks:
            lines.append(f"{'✅' if check['ok'] else '❌'} {check['name']}: {check['detail']}")
