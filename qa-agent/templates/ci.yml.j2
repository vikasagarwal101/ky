# Ceph QA — Autonomous repository quality workflow
# Generated by `ceph ci {{ repo_name }}`
name: Ceph QA

on:
  push:
    branches:
      - main
      - master
  pull_request:
    branches:
      - main
      - master
  workflow_dispatch:
    inputs:
      phase:
        description: 'QA cycle phase to run'
        required: true
        default: 'orchestrated'
        type: choice
        options:
          - issue-cycle
          - pr-cycle
          - review-cycle
          - merge-cycle
          - orchestrated

env:
  PYTHON_VERSION: "3.11"
  CEPH_DIR: ${{ github.workspace }}/.ceph
  REPO_PATH: ${{ github.workspace }}

jobs:
  qa-scan:
    name: Ceph QA Scan
    runs-on: ubuntu-latest
    timeout-minutes: 30
    permissions:
      contents: read
      issues: write
      pull-requests: write
      checks: write

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - name: Setup Python
        uses: actions/setup-python@v5
        with:
          python-version: ${{ env.PYTHON_VERSION }}

      - name: Install Ceph QA Agent
        run: |
          pip install --upgrade pip
          pip install -e __CEPH_INSTALL_PATH__

      - name: Install system dependencies
        run: |
          sudo apt-get update -qq
          sudo apt-get install -y -qq shellcheck 2>/dev/null || true
          if command -v node &>/dev/null; then
            npm install -g markdownlint-cli actionlint 2>/dev/null || true
          fi

      - name: Run Ceph Scan
        id: ceph-scan
        continue-on-error: true
        run: |
          ceph scan . \
            --phase ${{ github.event.inputs.phase || 'issue-cycle' }} \
            --format json 2>&1 | tee ceph-output.json

      - name: Upload Findings Artifact
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: ceph-findings
          path: |
            ceph-output.json
            .ceph/state/*.json
            .ceph/logs/*.log
          retention-days: 14
          if-no-files-found: warn

      - name: Post findings summary
        if: steps.ceph-scan.outcome == 'success' || steps.ceph-scan.outcome == 'failure'
        run: |
          echo "## Ceph QA Results" >> $GITHUB_STEP_SUMMARY
          echo "" >> $GITHUB_STEP_SUMMARY
          if [ -f ceph-output.json ]; then
            echo '```json' >> $GITHUB_STEP_SUMMARY
            head -c 2000 ceph-output.json >> $GITHUB_STEP_SUMMARY
            echo '' >> $GITHUB_STEP_SUMMARY
            echo '```' >> $GITHUB_STEP_SUMMARY
          else
            echo "No ceph-output.json found — scan may have failed early." >> $GITHUB_STEP_SUMMARY
          fi
